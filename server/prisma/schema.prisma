// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String

  // Set at registration
  name String

  // Mandatory for completing onboarding's profile step (enforced in app, not DB —
  // a user exists before these are filled in)
  dateOfBirth           DateTime?
  employmentType        String? // "salaried" | "self_employed" | "business" | "student" | "retired"
  monthlyIncomeEstimate Float? // seeds cost-ratio before granular income entries exist

  // Optional profile fields — each has a UI-side "impact if missing" message
  phone               String?
  dependentsCount     Int?
  existingMonthlyEmi  Float?
  riskAppetite        String? // "conservative" | "moderate" | "aggressive" — defaulted by age if unset
  cityTier            String? // "metro" | "tier2" | "tier3" | "rural"
  maritalStatus       String? // "single" | "married"
  lifeInsuranceCover  Float?
  healthInsuranceCover Float?
  taxRegime           String? // "old" | "new"
  emergencyFundMonths Float?
  existingSavingsAmount Float? // declared lump-sum existing savings, used to seed portfolio advice
  existingSavingsNotes  String?

  onboardingStep        String    @default("profile") // "profile" | "income" | "fixed_costs" | "invest" | "done"
  onboardingCompletedAt DateTime?
  createdAt              DateTime @default(now())

  incomes               Income[]
  loans                 Loan[]
  subscriptions         Subscription[]
  transactions          Transaction[]
  creditCards           CreditCard[]
  investmentInstruments InvestmentInstrument[]
  goals                 Goal[]
  importedTransactions  ImportedTransaction[]
  emailAccounts         EmailAccount[]
  budgetEstimates       BudgetEstimate[]
}

model Income {
  id                  Int      @id @default(autoincrement())
  userId              Int?
  user                User?    @relation(fields: [userId], references: [id])
  month               String // "YYYY-MM" — in-hand earnings, denominator for the 50% cost-ratio rule
  source              String
  amount              Float
  type                String   @default("salary") // "salary" | "passive" | "reimbursement"
  isFamilyIncome      Boolean  @default(false)
  linkedTransactionId Int? // set when type = "reimbursement" — the original reimbursable expense this settles
  createdAt           DateTime @default(now())
}

model Loan {
  id                   Int       @id @default(autoincrement())
  userId               Int?
  user                 User?     @relation(fields: [userId], references: [id])
  name                 String // "Home Loan - HDFC"
  lenderName           String?
  loanType             String // "home" | "personal" | "car" | "education" | "other"
  principalAmount      Float
  interestRatePct      Float // annual
  tenureMonths         Int
  emiAmount            Float
  loanStartDate        DateTime
  firstEmiDate         DateTime
  outstandingPrincipal Float? // manual update from latest statement; null = derive purely from elapsed EMIs
  status               String    @default("active") // "active" | "closed"
  createdAt            DateTime  @default(now())
}

model BudgetEstimate {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  category  String // "rent" | "fees" | "travel" | "dining" | "shopping" | "other"
  label     String?
  minAmount Float
  maxAmount Float // equal to minAmount for exact (non-range) costs like rent/fees
  createdAt DateTime @default(now())
}

model Category {
  id            Int            @id @default(autoincrement())
  name          String
  group         String // "expense" | "investment" | "credit_card"
  parentId      Int?
  parent        Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      Category[]     @relation("CategoryHierarchy")
  transactions  Transaction[]
  subscriptions Subscription[]
}

model Subscription {
  id              Int       @id @default(autoincrement())
  userId          Int?
  user            User?     @relation(fields: [userId], references: [id])
  name            String // "Airtel Postpaid", "JioFiber Wifi", "Netflix" ...
  categoryId      Int
  category        Category  @relation(fields: [categoryId], references: [id])
  amount          Float
  billingCycle    String // "monthly" | "quarterly" | "yearly"
  nextRenewalDate DateTime
  autoDebit       Boolean   @default(false)
  notes           String?
  createdAt       DateTime  @default(now())
}

model Transaction {
  id                  Int      @id @default(autoincrement())
  userId              Int?
  user                User?    @relation(fields: [userId], references: [id])
  date                DateTime
  categoryId          Int
  category            Category @relation(fields: [categoryId], references: [id])
  amount               Float
  remarks             String?
  month               String // "YYYY-MM"
  necessity           String // "must_have" | "good_to_have" | "not_needed"
  isReimbursable      Boolean  @default(false)
  reimbursementParty  String? // who owes this back (employer, friend, etc.)
  reimbursementStatus String? // "pending" | "received" — null when isReimbursable is false
  createdAt           DateTime @default(now())
}

model CreditCard {
  id            Int                 @id @default(autoincrement())
  userId        Int?
  user          User?               @relation(fields: [userId], references: [id])
  name          String // SBI / Axis / Kotak
  rewardProfile Json // { category: rewardRatePct, ... } + milestone bonuses, annual fee
  payments      CreditCardPayment[]
}

model CreditCardPayment {
  id                     Int        @id @default(autoincrement())
  creditCardId           Int
  creditCard             CreditCard @relation(fields: [creditCardId], references: [id])
  month                  String
  amount                 Float
  estimatedRewardsEarned Float      @default(0)
}

model InvestmentInstrument {
  id                      Int                      @id @default(autoincrement())
  userId                  Int?
  user                    User?                    @relation(fields: [userId], references: [id])
  name                    String // PPF / NPS / Mutual Fund / Sukanya Samridhi / Gold ...
  expectedAnnualReturnPct Float // user-editable; seeded with sane defaults (PPF 7.1, SSY 8.2, NPS ~10, MF ~12, Gold ~8)
  lockInYears             Float?
  taxBenefitNotes         String?
  contributions           InvestmentContribution[]
}

model InvestmentContribution {
  id           Int                  @id @default(autoincrement())
  instrumentId Int
  instrument   InvestmentInstrument @relation(fields: [instrumentId], references: [id])
  month        String
  amount       Float
  runningValue Float // tracked actual value, since instrument returns aren't linear
}

model Goal {
  id           Int      @id @default(autoincrement())
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
  name         String // e.g. "₹30L by Apr 2030"
  targetAmount Float
  targetDate   DateTime
  riskAppetite String? // "conservative" | "moderate" | "aggressive" — defaults to User.riskAppetite if unset
}

model ImportedTransaction {
  id                  Int      @id @default(autoincrement())
  userId              Int?
  user                User?    @relation(fields: [userId], references: [id])
  date                DateTime
  description         String
  amount              Float
  categoryGuess       String?
  sourceFile          String
  reconciled          Boolean  @default(false)
  linkedTransactionId Int?
}

model EmailAccount {
  id           Int                @id @default(autoincrement())
  userId       Int?
  user         User?              @relation(fields: [userId], references: [id])
  emailAddress String             @unique
  provider     String // "gmail" | "imap"
  authType     String // "oauth" | "imap_password"
  credentials  Json // encrypted (AES-256-GCM) OAuth tokens or IMAP host/port/app-password — never stored plaintext
  lastSyncedAt DateTime?
  createdAt    DateTime           @default(now())
  transactions EmailTransaction[]
}

model EmailTransaction {
  id                  Int          @id @default(autoincrement())
  emailAccountId      Int
  emailAccount        EmailAccount @relation(fields: [emailAccountId], references: [id])
  receivedAt          DateTime
  sourceLabel         String // e.g. "SBI Card", "Axis Bank", "UPI-GPay" — derived from sender domain
  mode                String // "credit_card" | "upi" | "bank_debit" | "bank_credit"
  parsedAmount        Float
  parsedMerchant      String?
  rawSnippet          String // minimal text kept for audit, not the full email body
  reconciled          Boolean      @default(false)
  linkedTransactionId Int?
  createdAt           DateTime     @default(now())
}
